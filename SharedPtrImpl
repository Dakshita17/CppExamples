template<typename T>
class SharedPtr{

    private:
        T* ptr;
        int* count;


    public:
        SharedPtr(T* other);

        ~SharedPtr();

        SharedPtr(const SharedPtr& other);

        SharedPtr& operator=(const SharedPtr& other);

        SharedPtr(SharedPtr&& other);

        SharedPtr& operator=(SharedPtr&& other);


};


template<typename T>
SharedPtr<T>::SharedPtr(T* other){

    ptr = other;
    count = new int(1);
}

template<typename T>
 SharedPtr<T>::~SharedPtr<T>(){

    if (count == nullptr)
        return;
    (*count)--;
    if(*count == 0)
    {
        delete ptr;
        delete count;
    }

 }



template<typename T>
SharedPtr<T>::SharedPtr(const SharedPtr<T>& other){

    ptr = other.ptr;
    count = other.count;
    (*count)++;


}

template<typename T>
SharedPtr<T>& SharedPtr<T>::operator=(SharedPtr<T>&& other)
{

     if(this == &other)
        return *this;

    // release current ownership
    if(count != nullptr)
    {
        (*count)--;

        if(*count == 0)
        {
            delete ptr;
            delete count;
        }
    }
    ptr = other.ptr;
    count = other.count;

    other.ptr = nullptr;
    other.count = nullptr;

    return *this;
}


template<typename T>
SharedPtr<T>::SharedPtr(SharedPtr<T>&& other){

    ptr = other.ptr;
    count = other.count;
    other.ptr = nullptr;
    other.count = nullptr;


}


template<typename T>
SharedPtr<T>& SharedPtr<T>::operator=(const SharedPtr<T>& other)
{
    if(this == &other)
        return *this;

    // remove current ownership
    if(count != nullptr)
    {
        (*count)--;

        if(*count == 0)
        {
            delete ptr;
            delete count;
        }
    }

    // share other's resource
    ptr = other.ptr;
    count = other.count;

    (*count)++;

    return *this;
}




int main(){

    SharedPtr<int>s1(new int(2));


    SharedPtr<int>s2(new int(2));

    SharedPtr<int>s3(s1);



}


