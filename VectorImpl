#include<iostream>
#include<initializer_list>

using namespace std;

template<typename T>
class Vector{

    T* data;
    int size;
    int capacity;

    public:

    Vector();

    ~Vector();

    Vector(initializer_list<T> l)
    {
        size = l.size();
        capacity = 2*size;
        data = new T[capacity];

        int index  = 0;
        for(const T& elem: l)
        {
            data[index++] = elem;
        }
    }

    Vector(const Vector<T>& other);

    Vector& operator=(const Vector<T>& other);

    Vector(Vector<T>&& other);

    Vector& operator=(Vector<T>&& other);

    T& operator[]( int index); // Why is T operator[](const Vector& v, int index); incorrect 

    T& at(int index);

    const T& front();

    const T& back();

    int size_();

    int capacity_();

    void reserve(int c);

    void push_back(const T& ele);

    void pop_back();

    void clear();

    void push_back(T&& ele); // not implemebted yet

    bool empty();

    T* begin();

    T* end();

    template<typename... Args>
    void emplace_back(Args&&... args);

    void resize(int new_size);


};

